---
const { title = "Evamor Africa" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const hash = window.location.hash || "";
        const normalizedHash = hash.startsWith("#/") ? `#${hash.slice(2)}` : hash;
        const hasIdentityToken =
          normalizedHash.includes("invite_token=") ||
          normalizedHash.includes("recovery_token=") ||
          normalizedHash.includes("confirmation_token=");

        if (hasIdentityToken && !window.location.pathname.startsWith("/admin")) {
          window.location.replace(`/admin/${normalizedHash}`);
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="nav-shell">
        <a href="/" class="logo">Evamor Africa</a>
        <nav>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/what-we-do">What We Do</a></li>
            <li><a href="/projects">Projects</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/our-team">Team</a></li>
            <li><a href="/gallery">Gallery</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-shell">
        <p>&copy; {new Date().getFullYear()} Evamor Africa</p>
      </div>
    </footer>

    <style>
      :root {
        --evamor-green: #4baf47;
        --evamor-green-dark: #2f8f36;
        --evamor-ink: #1f2937;
        --evamor-muted: #4b5563;
        --evamor-card: #ffffff;
        --evamor-line: #d7e6d4;
        --evamor-bg: #f6faf3;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--evamor-ink);
        font-family: "Manrope", system-ui, sans-serif;
        background:
          radial-gradient(circle at 12% 0%, #e3f3df 0%, transparent 34%),
          radial-gradient(circle at 88% 4%, #deefd9 0%, transparent 30%),
          var(--evamor-bg);
      }

      header {
        position: sticky;
        top: 0;
        z-index: 40;
        backdrop-filter: blur(12px);
        background: rgba(244, 248, 247, 0.88);
        border-bottom: 1px solid var(--evamor-line);
      }

      .nav-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .logo {
        font-family: "Space Grotesk", "Manrope", sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.01em;
        color: var(--evamor-green-dark);
        text-decoration: none;
      }

      nav ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.2rem;
      }

      nav a {
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        padding: 0 0.75rem;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--evamor-muted);
        text-decoration: none;
        transition: background 0.2s ease, color 0.2s ease;
      }

      nav a:hover {
        background: #e9f6e7;
        color: var(--evamor-green-dark);
      }

      main {
        width: min(1080px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 3.2rem 0 4rem;
      }

      footer {
        border-top: 1px solid var(--evamor-line);
        background: rgba(255, 255, 255, 0.8);
      }

      .footer-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 1rem 1.25rem;
        color: var(--evamor-muted);
        font-size: 0.9rem;
      }

      h1,
      h2,
      h3 {
        color: var(--evamor-ink);
        line-height: 1.2;
        margin: 0 0 1rem;
      }

      h1 {
        font-family: "Space Grotesk", "Manrope", sans-serif;
        font-size: clamp(2rem, 3.2vw, 3rem);
      }

      h2 {
        font-size: clamp(1.4rem, 2.2vw, 2rem);
        margin-top: 2rem;
      }

      p {
        margin: 0 0 1rem;
        line-height: 1.75;
        color: var(--evamor-muted);
      }

      .page-hero {
        padding: 2rem;
        border-radius: 22px;
        background: linear-gradient(140deg, #3e9940 0%, #4baf47 55%, #27ae60 100%);
        color: #ffffff;
        box-shadow: 0 24px 44px rgba(62, 153, 64, 0.24);
      }

      .page-hero p {
        color: rgba(255, 255, 255, 0.9);
        max-width: 72ch;
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 0.75rem;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.17);
      }

      .grid-cards {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
        content-visibility: auto;
        contain-intrinsic-size: 1px 900px;
      }

      .card {
        border: 1px solid var(--evamor-line);
        background: var(--evamor-card);
        border-radius: 16px;
        padding: 1.2rem;
        box-shadow: 0 14px 28px rgba(12, 35, 27, 0.06);
      }

      .card h3 {
        margin-bottom: 0.6rem;
        font-size: 1.08rem;
      }

      .card p {
        margin-bottom: 0.85rem;
      }

      .read-more {
        color: var(--evamor-green-dark);
        font-size: 0.9rem;
        font-weight: 700;
        text-decoration: none;
      }

      .read-more:hover {
        text-decoration: underline;
      }

      .content-list {
        margin: 1rem 0 1.5rem;
        padding-left: 1.1rem;
      }

      .content-list li {
        margin-bottom: 0.45rem;
        color: var(--evamor-muted);
      }

      .focus-areas {
        margin-top: 2.2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
        content-visibility: auto;
        contain-intrinsic-size: 1px 1000px;
      }

      .focus-areas article {
        border: 1px solid var(--evamor-line);
        background: var(--evamor-card);
        border-radius: 16px;
        padding: 1.2rem;
        box-shadow: 0 12px 24px rgba(12, 35, 27, 0.06);
      }

      .gallery-grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
        content-visibility: auto;
        contain-intrinsic-size: 1px 1200px;
      }

      .gallery-grid figure {
        margin: 0;
        border: 1px solid var(--evamor-line);
        background: var(--evamor-card);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 12px 24px rgba(12, 35, 27, 0.06);
      }

      .gallery-grid img {
        display: block;
        width: 100%;
        height: auto;
      }

      .gallery-grid figcaption {
        padding: 0.75rem 0.85rem 0.95rem;
        color: var(--evamor-muted);
        font-size: 0.9rem;
      }

      .contact-grid {
        margin-top: 2rem;
        display: grid;
        gap: 1.2rem;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      }

      .contact-grid > div {
        background: var(--evamor-card);
        border: 1px solid var(--evamor-line);
        border-radius: 16px;
        padding: 1.25rem;
      }

      .contact-details {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
      }

      .contact-details li {
        margin-bottom: 0.45rem;
      }

      .contact-form {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
      }

      .contact-form input,
      .contact-form textarea {
        margin-top: 0.35rem;
        width: 100%;
        font: inherit;
        border-radius: 10px;
        border: 1px solid var(--evamor-line);
        padding: 0.6rem 0.75rem;
        background: #fbfdfc;
      }

      .contact-form button {
        border: none;
        border-radius: 10px;
        padding: 0.7rem 0.95rem;
        width: fit-content;
        font: inherit;
        font-weight: 700;
        color: #ffffff;
        background: var(--evamor-green);
        cursor: pointer;
      }

      @media (max-width: 780px) {
        .nav-shell {
          flex-direction: column;
          align-items: flex-start;
        }

        main {
          width: min(1080px, calc(100% - 1.25rem));
          padding-top: 2rem;
        }

        .page-hero {
          padding: 1.4rem;
        }
      }
    </style>
  </body>
</html>
