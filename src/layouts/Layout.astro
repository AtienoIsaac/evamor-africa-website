---
const { title = "Evamor Africa" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const hash = window.location.hash || "";
        const normalizedHash = hash.startsWith("#/") ? `#${hash.slice(2)}` : hash;
        const hasIdentityToken =
          normalizedHash.includes("invite_token=") ||
          normalizedHash.includes("recovery_token=") ||
          normalizedHash.includes("confirmation_token=");

        if (hasIdentityToken && !window.location.pathname.startsWith("/admin")) {
          window.location.replace(`/admin/${normalizedHash}`);
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Syne:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="nav-shell">
        <a href="/" class="logo">
          <span class="logo-mark" aria-hidden="true"></span>
          <span>Evamor Africa</span>
        </a>
        <div class="nav-actions">
          <nav>
            <ul>
              <li><a href="/about">About</a></li>
              <li><a href="/what-we-do">What We Do</a></li>
              <li><a href="/projects">Projects</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/our-team">Team</a></li>
              <li><a href="/gallery">Gallery</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </nav>
          <a href="/contact" class="nav-cta">Partner</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-shell">
        <p>&copy; {new Date().getFullYear()} Evamor Africa</p>
      </div>
    </footer>

    <style>
      :root {
        --evamor-green: #4baf47;
        --evamor-green-dark: #2f8f36;
        --evamor-lime: #89d25d;
        --evamor-ink: #182119;
        --evamor-muted: #4b5c4e;
        --evamor-card: #ffffff;
        --evamor-line: #dbe8d2;
        --evamor-bg: #f7fbf3;
        --shadow-soft: 0 16px 40px rgba(23, 61, 30, 0.08);
        --shadow-raise: 0 20px 40px rgba(38, 118, 44, 0.2);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--evamor-ink);
        font-family: "Plus Jakarta Sans", system-ui, sans-serif;
        background:
          radial-gradient(circle at 10% -8%, #e5f7d8 0%, transparent 42%),
          radial-gradient(circle at 88% 4%, #e2f3d8 0%, transparent 34%),
          var(--evamor-bg);
        position: relative;
        min-height: 100vh;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        border-radius: 999px;
        pointer-events: none;
        z-index: -1;
      }

      body::before {
        width: min(46vw, 540px);
        height: min(46vw, 540px);
        right: -16vw;
        top: 16vh;
        background: radial-gradient(circle, rgba(75, 175, 71, 0.2) 0%, rgba(75, 175, 71, 0) 72%);
      }

      body::after {
        width: min(34vw, 420px);
        height: min(34vw, 420px);
        left: -11vw;
        bottom: 12vh;
        background: radial-gradient(circle, rgba(137, 210, 93, 0.22) 0%, rgba(137, 210, 93, 0) 70%);
      }

      header {
        position: sticky;
        top: 0.75rem;
        z-index: 50;
      }

      .nav-shell {
        width: min(1180px, calc(100% - 1.5rem));
        margin: 0 auto;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 18px;
        background: linear-gradient(120deg, rgba(255, 255, 255, 0.83), rgba(247, 252, 243, 0.86));
        backdrop-filter: blur(14px);
        box-shadow: var(--shadow-soft);
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: "Syne", "Plus Jakarta Sans", sans-serif;
        font-size: 1.08rem;
        font-weight: 700;
        letter-spacing: 0.015em;
        color: var(--evamor-green-dark);
        text-decoration: none;
      }

      .logo-mark {
        width: 28px;
        height: 28px;
        border-radius: 9px;
        background: conic-gradient(from 235deg, #2f8f36, #69c74f, #4baf47, #2f8f36);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.55);
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }

      nav ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
      }

      nav a {
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        padding: 0 0.82rem;
        border-radius: 999px;
        font-size: 0.86rem;
        font-weight: 600;
        color: #3d4e41;
        text-decoration: none;
        transition: background 0.24s ease, color 0.24s ease, transform 0.24s ease;
      }

      nav a:hover {
        transform: translateY(-1px);
        background: #edf8e7;
        color: var(--evamor-green-dark);
      }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 38px;
        padding: 0 0.95rem;
        border-radius: 11px;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.84rem;
        font-weight: 700;
        letter-spacing: 0.01em;
        background: linear-gradient(120deg, #3a9a3d, #4baf47 55%, #5cbf55);
        box-shadow: 0 10px 24px rgba(58, 154, 61, 0.3);
        transition: transform 0.24s ease, box-shadow 0.24s ease;
      }

      .nav-cta:hover {
        transform: translateY(-1px);
        box-shadow: 0 14px 28px rgba(58, 154, 61, 0.35);
      }

      main {
        width: min(1140px, calc(100% - 1.5rem));
        margin: 0 auto;
        padding: 2.5rem 0 4.4rem;
      }

      footer {
        border-top: 1px solid rgba(176, 203, 160, 0.35);
        background: rgba(255, 255, 255, 0.68);
      }

      .footer-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 1rem 1.2rem;
        color: var(--evamor-muted);
        font-size: 0.86rem;
      }

      h1,
      h2,
      h3 {
        color: var(--evamor-ink);
        line-height: 1.15;
        margin: 0 0 1rem;
      }

      h1 {
        font-family: "Syne", "Plus Jakarta Sans", sans-serif;
        font-size: clamp(2rem, 4.4vw, 3.5rem);
        letter-spacing: -0.01em;
      }

      h2 {
        font-family: "Syne", "Plus Jakarta Sans", sans-serif;
        font-size: clamp(1.3rem, 2.2vw, 1.95rem);
        margin-top: 2rem;
      }

      p {
        margin: 0 0 1rem;
        line-height: 1.72;
        color: var(--evamor-muted);
      }

      .page-hero {
        position: relative;
        overflow: hidden;
        isolation: isolate;
        padding: clamp(1.5rem, 3.8vw, 2.6rem);
        border-radius: 28px;
        background:
          linear-gradient(130deg, rgba(45, 137, 55, 0.97) 0%, rgba(75, 175, 71, 0.97) 56%, rgba(39, 174, 96, 0.95) 100%);
        color: #ffffff;
        box-shadow: var(--shadow-raise);
        animation: rise-in 0.58s ease both;
      }

      .page-hero::before,
      .page-hero::after {
        content: "";
        position: absolute;
        border-radius: 999px;
        z-index: -1;
      }

      .page-hero::before {
        width: 420px;
        height: 420px;
        right: -200px;
        top: -220px;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0) 72%);
      }

      .page-hero::after {
        width: 240px;
        height: 240px;
        left: -130px;
        bottom: -120px;
        background: radial-gradient(circle, rgba(137, 210, 93, 0.25) 0%, rgba(137, 210, 93, 0) 70%);
      }

      .page-hero p {
        color: rgba(255, 255, 255, 0.9);
        max-width: 64ch;
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 0.95rem;
        padding: 0.35rem 0.78rem;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.2);
      }

      .grid-cards {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.05rem;
        content-visibility: auto;
        contain-intrinsic-size: 1px 900px;
      }

      .card {
        border: 1px solid rgba(216, 231, 206, 0.9);
        background:
          linear-gradient(160deg, #ffffff 0%, #fcfffa 100%),
          var(--evamor-card);
        border-radius: 18px;
        padding: 1.3rem;
        box-shadow: var(--shadow-soft);
        transition: transform 0.26s ease, box-shadow 0.26s ease, border-color 0.26s ease;
        animation: rise-in 0.5s ease both;
      }

      .card h3 {
        margin-bottom: 0.6rem;
        font-size: 1.12rem;
      }

      .card p {
        margin-bottom: 0.85rem;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: rgba(75, 175, 71, 0.28);
        box-shadow: 0 24px 40px rgba(32, 82, 34, 0.12);
      }

      .read-more {
        color: var(--evamor-green-dark);
        font-size: 0.9rem;
        font-weight: 700;
        text-decoration: none;
        position: relative;
      }

      .read-more::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -3px;
        width: 100%;
        height: 2px;
        transform: scaleX(0);
        transform-origin: left;
        background: currentColor;
        transition: transform 0.22s ease;
      }

      .read-more:hover::after {
        transform: scaleX(1);
      }

      .content-list {
        margin: 1rem 0 1.5rem;
        padding-left: 1.1rem;
      }

      .content-list li {
        margin-bottom: 0.45rem;
        color: var(--evamor-muted);
      }

      .focus-areas {
        margin-top: 2.2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.05rem;
        content-visibility: auto;
        contain-intrinsic-size: 1px 1000px;
      }

      .focus-areas article {
        border: 1px solid rgba(216, 231, 206, 0.9);
        background: var(--evamor-card);
        border-radius: 18px;
        padding: 1.25rem;
        box-shadow: var(--shadow-soft);
        animation: rise-in 0.5s ease both;
      }

      .gallery-grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.05rem;
        content-visibility: auto;
        contain-intrinsic-size: 1px 1200px;
      }

      .gallery-grid figure {
        margin: 0;
        border: 1px solid rgba(216, 231, 206, 0.9);
        background: var(--evamor-card);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: var(--shadow-soft);
        transition: transform 0.26s ease, box-shadow 0.26s ease;
        animation: rise-in 0.5s ease both;
      }

      .gallery-grid img {
        display: block;
        width: 100%;
        height: auto;
        transition: transform 0.4s ease;
      }

      .gallery-grid figure:hover {
        transform: translateY(-4px);
        box-shadow: 0 24px 40px rgba(32, 82, 34, 0.12);
      }

      .gallery-grid figure:hover img {
        transform: scale(1.03);
      }

      .gallery-grid figcaption {
        padding: 0.8rem 0.9rem 1rem;
        color: var(--evamor-muted);
        font-size: 0.88rem;
      }

      .contact-grid {
        margin-top: 2rem;
        display: grid;
        gap: 1.05rem;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      }

      .contact-grid > div {
        background: var(--evamor-card);
        border: 1px solid rgba(216, 231, 206, 0.9);
        border-radius: 18px;
        padding: 1.25rem;
        box-shadow: var(--shadow-soft);
        animation: rise-in 0.5s ease both;
      }

      .contact-details {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
      }

      .contact-details li {
        margin-bottom: 0.45rem;
      }

      .contact-form {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
      }

      .contact-form input,
      .contact-form textarea {
        margin-top: 0.35rem;
        width: 100%;
        font: inherit;
        border-radius: 12px;
        border: 1px solid #d9e8d2;
        padding: 0.68rem 0.8rem;
        background: #fcfefb;
      }

      .contact-form input:focus,
      .contact-form textarea:focus {
        outline: none;
        border-color: #88c460;
        box-shadow: 0 0 0 4px rgba(136, 196, 96, 0.18);
      }

      .contact-form button {
        border: none;
        border-radius: 12px;
        padding: 0.72rem 1rem;
        width: fit-content;
        font: inherit;
        font-weight: 700;
        color: #ffffff;
        background: linear-gradient(120deg, #3a9a3d, #4baf47 55%, #5cbf55);
        cursor: pointer;
        box-shadow: 0 10px 24px rgba(58, 154, 61, 0.28);
        transition: transform 0.24s ease, box-shadow 0.24s ease;
      }

      .contact-form button:hover {
        transform: translateY(-1px);
        box-shadow: 0 14px 28px rgba(58, 154, 61, 0.34);
      }

      .grid-cards > :nth-child(2),
      .focus-areas > :nth-child(2),
      .gallery-grid > :nth-child(2) {
        animation-delay: 70ms;
      }

      .grid-cards > :nth-child(3),
      .focus-areas > :nth-child(3),
      .gallery-grid > :nth-child(3) {
        animation-delay: 120ms;
      }

      @keyframes rise-in {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
        }
      }

      @media (max-width: 780px) {
        .nav-shell {
          flex-direction: column;
          align-items: flex-start;
          padding: 0.75rem;
        }

        .nav-actions {
          width: 100%;
          flex-direction: column;
          align-items: flex-start;
        }

        nav {
          width: 100%;
        }

        main {
          width: min(1140px, calc(100% - 1rem));
          padding-top: 1.6rem;
        }

        .nav-cta {
          width: 100%;
        }

        .page-hero {
          border-radius: 22px;
        }
      }
    </style>
  </body>
</html>
