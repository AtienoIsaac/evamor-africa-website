---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---
<Layout title="Gallery | Evamor Africa">
  <PageHero
    label="Gallery"
    title="Snapshots from programs, field activities, and partnerships"
    description="A visual record of community action across conservation, climate resilience, advocacy, and green enterprise initiatives."
  />

  <section class="gallery-grid">
    <figure>
      <img
        src="/images/gallery-1.jpg"
        alt="Community conservation activity"
        width="1346"
        height="897"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <figcaption>Community conservation initiative</figcaption>
    </figure>

    <figure>
      <img
        src="/images/gallery-2.jpg"
        alt="Climate-smart agriculture training"
        width="1600"
        height="1200"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Climate-smart agriculture training</figcaption>
    </figure>

    <figure>
      <img
        src="/images/gallery-3.jpg"
        alt="Eco-tourism site visit"
        width="1600"
        height="1067"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Eco-tourism site visit</figcaption>
    </figure>

    <figure>
      <img
        src="/images/gallery-4.jpg"
        alt="Sustainable transport discussion"
        width="2560"
        height="1707"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Sustainable transport engagement</figcaption>
    </figure>

    <figure>
      <img
        src="/images/gallery-5.jpg"
        alt="Environmental advocacy session"
        width="1280"
        height="720"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Environmental rights and advocacy session</figcaption>
    </figure>

    <figure>
      <img
        src="/images/gallery-6.jpg"
        alt="Green energy initiative"
        width="1346"
        height="897"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Green energy and green enterprising initiative</figcaption>
    </figure>
  </section>
</Layout>
