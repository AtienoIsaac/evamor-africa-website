---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
---

<Layout title="Evamor Eco-Couriers | Evamor Africa">
  <PageHero
    label="Program"
    title="Evamor Eco-Couriers"
    description="A zero-carbon courier model using electric bikes and integrated sustainability services for households and businesses."
  />

  <section class="grid-cards">
    <article class="card">
      <h3>The Challenge</h3>
      <p>
        Urban delivery demand is growing while transport emissions continue to
        rise. Communities need cleaner alternatives that also create decent work.
      </p>
    </article>
    <article class="card">
      <h3>Our Solution</h3>
      <p>
        Eco-Couriers combines e-bike delivery with a strong environmental model:
        high service quality, low operating emissions, and practical green
        enterprise support.
      </p>
      <ul class="content-list">
        <li>Electric bike courier services</li>
        <li>Waste sorting and collection support</li>
        <li>Sustainability audits and simple coaching for SMEs</li>
      </ul>
    </article>
    <article class="card">
      <h3>Expected Impact</h3>
      <ul class="content-list">
        <li>Reduced carbon emissions in urban logistics</li>
        <li>New green jobs and youth enterprise opportunities</li>
        <li>Better environmental practices among local businesses</li>
      </ul>
    </article>
  </section>
</Layout>
