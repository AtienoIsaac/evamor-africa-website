---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
---

<Layout title="Green City Campaign | Evamor Africa">
  <PageHero
    label="Campaign"
    title="Green City Campaign"
    description="A city-wide initiative to build cleaner neighborhoods through awareness, practical action, and environmental stewardship."
  />

  <section class="grid-cards">
    <article class="card">
      <h3>Campaign Focus</h3>
      <ul class="content-list">
        <li>Public awareness on waste, air quality, and climate risk</li>
        <li>Urban greening and restoration actions</li>
        <li>Community participation in cleaner city practices</li>
      </ul>
    </article>
    <article class="card">
      <h3>Progress Snapshot</h3>
      <ul class="content-list">
        <li>200+ residents reached through outreach sessions</li>
        <li>10 youth directly engaged in campaign action teams</li>
        <li>Over 35 households and local business points mapped for follow-up</li>
      </ul>
    </article>
    <article class="card">
      <h3>Why It Matters</h3>
      <p>
        Green cities protect public health, reduce pressure on ecosystems, and
        create resilient local economies. This campaign translates those goals
        into practical neighborhood-level action.
      </p>
    </article>
  </section>
</Layout>
