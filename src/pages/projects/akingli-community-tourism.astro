---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
---

<Layout title="Akingli Community Tourism | Evamor Africa">
  <PageHero
    label="Project"
    title="Akingli Community Tourism"
    description="A community tourism initiative that links conservation outcomes with local income generation and cultural visibility."
  />

  <section class="grid-cards">
    <article class="card">
      <h3>Project Purpose</h3>
      <p>
        This project supports community-owned tourism pathways that protect
        landscapes while creating practical livelihoods for households.
      </p>
    </article>
    <article class="card">
      <h3>Key Activities</h3>
      <ul class="content-list">
        <li>Community tourism planning and destination mapping</li>
        <li>Training on visitor readiness and service standards</li>
        <li>Conservation awareness and local stewardship engagement</li>
      </ul>
    </article>
    <article class="card">
      <h3>Expected Results</h3>
      <ul class="content-list">
        <li>Improved local enterprise opportunities</li>
        <li>Greater value for local culture and natural assets</li>
        <li>Stronger community incentives to conserve ecosystems</li>
      </ul>
    </article>
  </section>
</Layout>
