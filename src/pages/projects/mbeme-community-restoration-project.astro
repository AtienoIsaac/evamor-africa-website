---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
---

<Layout title="Mbeme Community Restoration Project | Evamor Africa">
  <PageHero
    label="Project"
    title="Mbeme Community Restoration Project"
    description="A restoration program focused on rebuilding ecosystem health while strengthening climate resilience for local communities."
  />

  <section class="grid-cards">
    <article class="card">
      <h3>Project Context</h3>
      <p>
        Communities in vulnerable landscapes face soil degradation, climate
        stress, and loss of biodiversity. Restoration is both an environmental
        and livelihood priority.
      </p>
    </article>
    <article class="card">
      <h3>Core Interventions</h3>
      <ul class="content-list">
        <li>Community-led restoration and planting actions</li>
        <li>Soil and water conservation practices</li>
        <li>Environmental education and stewardship mobilization</li>
      </ul>
    </article>
    <article class="card">
      <h3>Intended Impact</h3>
      <ul class="content-list">
        <li>Improved ecosystem function and biodiversity</li>
        <li>Higher resilience to drought and climate shocks</li>
        <li>Stronger community ownership of restoration outcomes</li>
      </ul>
    </article>
  </section>
</Layout>
