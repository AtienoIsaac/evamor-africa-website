---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CardGrid from "../components/CardGrid.astro";

const programs = [
  {
    title: "Natural Resource Conservation",
    description:
      "Protecting ecosystems and supporting communities that depend on healthy natural environments.",
    href: "/what-we-do/natural-resource-conservation",
  },
  {
    title: "Climate-Smart Agriculture",
    description:
      "Building resilient food systems with sustainable farming methods and local capacity support.",
    href: "/what-we-do/climate-smart-agriculture",
  },
  {
    title: "Eco-Tourism",
    description:
      "Conservation-linked tourism models that grow local income while preserving biodiversity.",
    href: "/what-we-do/eco-tourism",
  },
  {
    title: "Sustainable Transport",
    description:
      "Low-emission mobility approaches and climate-resilient transport planning for communities.",
    href: "/what-we-do/sustainable-transport",
  },
  {
    title: "Environmental Rights and Advocacy",
    description:
      "Policy and community advocacy to defend environmental rights and sustainable governance.",
    href: "/what-we-do/environmental-rights-advocacy",
  },
  {
    title: "Green Energy and Green Enterprising",
    description:
      "Supporting clean energy adoption and green entrepreneurship for durable local economies.",
    href: "/what-we-do/green-energy-enterprising",
  },
  {
    title: "Evamor Eco-Couriers",
    description:
      "A cleaner logistics concept connecting sustainable delivery with livelihood opportunities.",
    href: "/what-we-do/evamor-eco-couriers",
  },
  {
    title: "Green City Campaign",
    description:
      "City-focused sustainability action through greening, awareness, and multi-stakeholder engagement.",
    href: "/what-we-do/green-city-campaign",
  },
];
---

<Layout title="What We Do | Evamor Africa">
  <PageHero
    label="Programs"
    title="Programs designed for impact, resilience, and green growth"
    description="From conservation and climate-smart agriculture to transport and advocacy, our work connects environmental protection with practical opportunities for communities."
  />

  <CardGrid items={programs} />
</Layout>
