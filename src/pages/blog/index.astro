---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CardGrid from "../../components/CardGrid.astro";

const posts = [
  {
    title: "Make a Statement in Support of the Environment",
    description:
      "A spotlight article on practical ways communities and institutions can support environmental action.",
    href: "/blog/make-a-statement-support-of-the-environment",
    cta: "Read article",
  },
];
---

